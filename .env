NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=true
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { --font-ui-smaller: 12px; --font-ui-small: 12px; --font-ui-medium: 14px; --font-ui-large: 16px; --img-border-radius: 5px; } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=mod-macos is-frameless is-hidden-frameless obsidian-app native-scrollbars show-inline-title show-ribbon show-view-header css-settings-manager theme-light pln-hilite-mods pln-dv-mods pln-dv-count pln-pin-protect pln-boxed-tags hide-properties pln-props-heading pln-props-list pln-embd-mods pln-embd-link pln-embd-title pln-embd-first pln-rm-rside pln-rm-status pln-rm-tablist pln-rm-nt pln-rm-noteic pln-rm-scroll pln-rm-mac-tside pln-rm-srchSug pln-checkboxes pln-pdf-rm-co-meta pln-pdf-rm-co-links pln-cards-sort pln-cards-borders is-focused
USE_FULL_RESOLUTION_IMAGES=false
THEME=https://raw.githubusercontent.com/PipeItToDevNull/PLN/HEAD/theme.css
BASE_THEME=light
dgHomeLink=true
dgPassFrontmatter=false
dgShowBacklinks=false
dgShowLocalGraph=false
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=false
